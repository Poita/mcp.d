	"toolchainRequirements": {
		"frontend": ">=2.100.0",
		"dmd": ">=2.100.0",
		"ldc": ">=1.30.0"
	},
	"targetType": "library",
	"dependencies": {
		"vibe-d:data": "~>0.9.8",
		"vibe-d:http": "~>0.9.8",
		"openssl": "~>3.4",
		"jsonschema": "~>0.1.0",
		"jsonschema:vibe": "~>0.1.0"
	},
	"sourceFiles-windows": ["source/deimos/openssl/version_.di"],
	"configurations": [
		{
			"name": "library",
			"targetType": "library"
		},
		{
			"name": "conformance-server",
			"targetType": "executable",
			"targetName": "conformance-server",
			"mainSourceFile": "conformance/server.d",
			"sourcePaths": [
				"source"
			],
			"importPaths": [
				"source"
			]
		},
		{
			"name": "conformance-client",
			"targetType": "executable",
			"targetName": "conformance-client",
			"mainSourceFile": "conformance/client.d",
			"sourcePaths": [
				"source"
			],
			"importPaths": [
				"source"
			]
		}
	]
}
