{
	"name": "mrtr",
	"description": "MRTR (multi round-trip) example: stateless inputRequired/inputResponses over Streamable HTTP.",
	"license": "Apache-2.0",
	"dependencies": {
		"mcp": { "path": "../.." }
	},
	"configurations": [
		{
