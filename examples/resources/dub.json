{
	"name": "resources",
	"description": "MCP Resources example (server + self-verifying e2e client) over BOTH stdio and Streamable HTTP.",
	"license": "Apache-2.0",
	"dependencies": {
		"mcp-d": { "path": "../.." },
		"examples-common": { "path": "../common" }
	},
	"configurations": [
		{
			"name": "server",
			"targetType": "executable",
			"targetName": "resources-server",
			"mainSourceFile": "server.d",
			"excludedSourceFiles": ["client.d"]
		},
		{
			"name": "client",
			"targetType": "executable",
			"targetName": "resources-client",
			"mainSourceFile": "client.d",
			"excludedSourceFiles": ["server.d"]
		}
	]
}
