{
	"name": "sampling",
	"description": "MCP Sampling example (server + self-verifying client e2e) over BOTH stdio and Streamable HTTP for mcp.d (#354)",
	"license": "Apache-2.0",
	"dependencies": {
		"mcp-d": { "path": "../.." },
		"examples-common": { "path": "../common" }
	},
	"configurations": [
		{
			"name": "server",
			"targetType": "executable",
			"targetName": "sampling-server",
			"mainSourceFile": "server.d"
		},
		{
			"name": "client",
			"targetType": "executable",
			"targetName": "sampling-client",
			"mainSourceFile": "client.d"
		}
	]
}
