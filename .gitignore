.dub/
*.o
*.obj
*.a
*.lib
# dub build/test output binaries at the package root (named after the dub
# package + config, e.g. mcp-d, mcp-d-test-library, mcp-d-test-application).
# Pattern-based so a package rename does not silently un-ignore them.
/mcp
/mcp-d
*-test-library
*-test-application
__test__*__
dub.selections.json
conformance-results/

# build artifacts
conformance-server
conformance-client
calculator

# generated API documentation (see scripts/gen-docs.sh)
/docs/
/site/
docs.json
__dummy.html

# code coverage output (dub test --coverage) + lcov conversion
*.lst
lcov.info

# built example binaries (each examples/<name>/ is its own dub package whose
# server/client configs build <name>-server / <name>-client)
examples/*/*-server
examples/*/*-client

# Claude Code agent/session state
.claude/
